<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Game Portfolio</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #1a1a1a;
            color: #fff;
            margin: 0;
            padding: 40px 20px;
            text-align: center;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
        }
        h1 { color: #fa5c5c; }
        
        /* Social Media Section Styling */
        .social-links {
            margin: 25px 0 40px 0;
        }
        .social-btn {
            display: inline-block;
            padding: 10px 20px;
            margin: 5px;
            color: #fff;
            text-decoration: none;
            border-radius: 4px;
            font-weight: bold;
            font-size: 14px;
            transition: opacity 0.2s;
        }
        .social-btn:hover { opacity: 0.8; }
        .fb { background-color: #1877f2; }
        .ig { background-color: #e1306c; }
        .x-com { background-color: #000000; border: 1px solid #333; }
        .yt { background-color: #ff0000; }

        .widget-container {
            margin: 30px auto;
            max-width: 552px; /* Matches your widget widths */
        }
        .video-container {
            position: relative;
            padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
            height: 0;
            overflow: hidden;
            max-width: 552px;
            margin: 0 auto;
        }
        .video-container iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: 0;
        }
        h2 {
            color: #dadada;
            margin-top: 40px;
            border-bottom: 1px solid #333;
            padding-bottom: 10px;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>JohnnyPeps</h1>
        <p>Game Developer & Storyteller</p>
        
        <!-- SOCIAL MEDIA LINK TREE -->
        <div class="social-links">
            <a href="https://www.facebook.com/thelastone" target="_blank" class="social-btn fb">Facebook</a>
            <a href="https://www.instagram.com/johnnypeps/" target="_blank" class="social-btn ig">Instagram</a>
            <a href="https://x.com/JohnnyDKin" target="_blank" class="social-btn x-com">X / Twitter</a>
            <a href="https://www.youtube.com/@johnnyDKin" target="_blank" class="social-btn yt">YouTube Channel</a>
        </div>

        <h2>My Indie Games</h2>
        
        <!-- FIRST GAME: TOXIC RELATIONSHIP -->
        <div class="widget-container">
            <iframe frameborder="0" src="https://itch.io/embed/4695680" width="552" height="167"><a href="https://johnnypeps.itch.io/toxic-relationship">Toxic Relationship by JohnnyPeps</a></iframe>
        </div>

        <!-- SECOND GAME: PARALEGAL SIMULATOR -->
        <div class="widget-container">
            <iframe frameborder="0" src="https://itch.io/embed/4677444" width="552" height="167"><a href="https://johnnypeps.itch.io/paralegal-simulator">Paralegal Simulator by JohnnyPeps</a></iframe>
        </div>

        <h2>Featured Video</h2>
        <!-- YOUTUBE EMBED PLAYER -->
        <div class="widget-container">
            <div class="video-container">
                <!-- Replace the video ID 'dQw4w9WgXcQ' in the src below with your actual featured video ID later if you want! -->
                <iframe src="https://www.youtube.com/embed?listType=user_uploads&list=johnnyDKin" allowfullscreen></iframe>
            </div>
        </div>
        
    </div>

</body>
</html>
